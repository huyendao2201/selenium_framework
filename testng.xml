<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo Test Suite">
    

    <!-- Group "smoke" chỉ chạy SmokeCases -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke" />
            </run>
        </groups>
        <classes>
            <class name="com.hcmunre.tests.LoginDataDrivenTest" />
        </classes>
    </test>

    <!-- Group "regression" chạy tất cả 3 sheet (Smoke, Negative, Boundary) -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="smoke" />
                <include name="regression" />
            </run>
        </groups>
        <classes>
            <class name="com.hcmunre.tests.LoginDataDrivenTest" />
            <class name="com.hcmunre.tests.RefactoredClassicTest" />
        </classes>
    </test>

    <test name="Lab Refactor">
        <classes>
            <class name="com.hcmunre.tests.RefactoredClassicTest" />
        </classes>
    </test>

</suite>
