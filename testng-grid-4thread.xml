<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Grid 4 Thread Suite" parallel="tests" thread-count="4">
    <test name="Chrome - LoginPageTest">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.hcmunre.tests.LoginPageTest"/>
        </classes>
    </test>

    <test name="Chrome - LoginDataDrivenTest">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.hcmunre.tests.LoginDataDrivenTest"/>
        </classes>
    </test>

    <test name="Firefox - LoginPageTest">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.hcmunre.tests.LoginPageTest"/>
        </classes>
    </test>

    <test name="Firefox - UserLoginJsonTest">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.hcmunre.tests.UserLoginJsonTest"/>
        </classes>
    </test>
</suite>