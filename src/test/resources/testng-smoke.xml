<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke Test Suite" parallel="tests" thread-count="2">

    <!-- Chrome -->
    <test name="Chrome Smoke Test">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.hcmunre.tests.LoginPageTest"/>
            <class name="com.hcmunre.tests.UserLoginJsonTest"/>
        </classes>
    </test>

    <!-- Firefox -->
    <test name="Firefox Smoke Test">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.hcmunre.tests.LoginPageTest"/>
            <class name="com.hcmunre.tests.UserLoginJsonTest"/>
        </classes>
    </test>

</suite>